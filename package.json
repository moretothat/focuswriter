{
  "name": "focuswriter",
  "version": "1.0.0",
  "description": "Distraction-free writing app that locks your computer until time is up",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build-win": "electron-builder --win",
    "build-all": "electron-builder --mac --win"
  },
  "author": "Your Name",
  "license": "proprietary",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.focuswriter.app",
    "productName": "FocusWriter",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "dmg": {
      "title": "FocusWriter",
      "backgroundColor": "#1a1a2e",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
